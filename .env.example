# openKuroneko 环境变量示例
# 复制为 .env 并填写实际值

# LLM
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o
# 工具调用线格式：openai（OpenAI/Kimi）| minimal（GLM）。Kimi 下可省略（按 baseUrl 自动选 openai）
# OPENAI_TOOL_WIRE_FORMAT=openai
# 调试 LLM 请求/响应时设 DEBUG_LLM=1（会向 stderr 打印 tool_calls 等）
# DEBUG_LLM=1

# Mem0（全局单实例）
MEM0_API_KEY=
MEM0_BASE_URL=http://localhost:8000

# Agent 运行时全局临时目录（默认 /tmp/openkuroneko）
OPENKURONEKO_TMP=/tmp/openkuroneko

# web_search 引擎：curl（默认，无需安装浏览器）| playwright（需运行 npx playwright install chromium）
OPENKURONEKO_SEARCH_ENGINE=curl

# 飞书（@ 判断使用 open_id 与 mentions 匹配，需配置本机机器人 open_id）
# FEISHU=1
# FEISHU_APP_ID=cli_xxx
# FEISHU_APP_SECRET=xxx
# FEISHU_MODE=websocket
# 本机机器人的 open_id，用于群内 @ 判断与过滤自身消息（必配，否则无法识别被 @）
# FEISHU_AGENT_OPEN_ID=ou_141ae8811fd13f0599a3201991abb4b7

# 消息中转（多 agent 飞书群聊上下文同步，与 relay 服务同配）
# 三者同时配置则启用：RELAY_URL=ws://localhost:9090 RELAY_KEY=xxx RELAY_AGENT_ID=kuroneko
RELAY_URL=
RELAY_KEY=
RELAY_AGENT_ID=
